        "timeout":  0,
        "outputs":  1,
        "func":  "msg.topic = \u0027CREATE TABLE IF NOT EXISTS gld_dataset (id INT UNSIGNED AUTO_INCREMENT PRIMARY KEY, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP, node_id VARCHAR(16), seq INT UNSIGNED, ts_ms BIGINT UNSIGNED, label VARCHAR(32), profile_id TINYINT UNSIGNED DEFAULT 0, ch0 FLOAT, ch1 FLOAT, ch2 FLOAT, ch3 FLOAT, ch4 FLOAT, ch5 FLOAT, ch6 FLOAT, ch7 FLOAT, gain0 TINYINT, gain1 TINYINT, gain2 TINYINT, gain3 TINYINT, gain4 TINYINT, gain5 TINYINT, gain6 TINYINT, gain7 TINYINT, ok0 TINYINT, ok1 TINYINT, ok2 TINYINT, ok3 TINYINT, ok4 TINYINT, ok5 TINYINT, ok6 TINYINT, ok7 TINYINT)\u0027; msg.payload = []; return msg;",
