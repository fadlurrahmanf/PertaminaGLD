# GLD Unified Firmware - Example Configuration
# Nilai final GLD sekarang dipusatkan di firmware/config/GldConfig.h.
# WiFi/MQTT server dataset dipusatkan di firmware/config/ServerConfig.h.
# File config lokal/provisioning TIDAK boleh di-commit jika berisi credentials produksi.
#
# Format di bawah hanya referensi untuk provisioning/env generator.

# Device Identity
GLD_NODE_ID=0xF001
GLD_DEVICE_ID_STR=F001
GLD_MQTT_CLIENT_ID=gld-unified-F001

# WiFi server dataset
GLD_WIFI_SSID=YourSSID
GLD_WIFI_PASSWORD=YourPassword

# MQTT server dataset
GLD_MQTT_HOST=CHANGE_ME_MQTT_HOST
GLD_MQTT_PORT=1884
GLD_MQTT_USER=<mqtt-user>
GLD_MQTT_PASS=<mqtt-pass>

# Timing (ms) - opsional, defaults ada di firmware/config/GldConfig.h
GLD_SCAN_INTERVAL_MS=1000
GLD_TX_INTERVAL_MS=10000
GLD_LORA_RX_WINDOW_MS=2000
