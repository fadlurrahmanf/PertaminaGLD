    {
        "id":  "pgld_ds_parse_record_fn",
        "y":  260,
        "initialize":  "",
        "name":  "parse record",
        "type":  "function",
        "z":  "pgld_ds_tab",
        "noerr":  0,
        "x":  400,
        "finalize":  "",
        "wires":  [
                      "pgld_ds_mysql_insert",
                      "pgld_ds_csv_row_fn",
                      "pgld_ds_debug_record"
                  ],
        "timeout":  0,
        "outputs":  1,
        "func":  "var p = (typeof msg.payload === \u0027string\u0027) ? JSON.parse(msg.payload) : msg.payload; if (!p || p.seq === undefined || !p.ch || p.ch.length !== 8) { node.warn(\u0027invalid record\u0027); return null; } var ch = p.ch, gain = p.gain || [0,0,0,0,0,0,0,0], ok = p.ok || [0,0,0,0,0,0,0,0]; msg.topic = \u0027INSERT INTO gld_dataset (node_id,seq,ts_ms,label,profile_id,ch0,ch1,ch2,ch3,ch4,ch5,ch6,ch7,gain0,gain1,gain2,gain3,gain4,gain5,gain6,gain7,ok0,ok1,ok2,ok3,ok4,ok5,ok6,ok7) VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)\u0027; msg.payload = [p.nodeId||\u0027\u0027,p.seq,p.ts_ms||0,p.label||\u0027\u0027,p.profileId||0,ch[0],ch[1],ch[2],ch[3],ch[4],ch[5],ch[6],ch[7],gain[0],gain[1],gain[2],gain[3],gain[4],gain[5],gain[6],gain[7],ok[0],ok[1],ok[2],ok[3],ok[4],ok[5],ok[6],ok[7]]; return msg;",
        "libs":  [

                 ]
    },
