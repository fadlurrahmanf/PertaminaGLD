        "finalize":  "",
        "wires":  [
                      "pgld_ds_csv_append_file"
                  ],
        "timeout":  0,
        "outputs":  1,
        "func":  "var p = (typeof msg.payload === \u0027string\u0027) ? JSON.parse(msg.payload) : msg.payload; if (!p || !p.ch) return null; var ch=p.ch, gain=p.gain||[0,0,0,0,0,0,0,0], ok=p.ok||[0,0,0,0,0,0,0,0]; msg.payload = [p.nodeId||\u0027\u0027,p.seq,p.ts_ms||0,p.label||\u0027\u0027,p.profileId||0].concat(ch).concat(gain).concat(ok).join(\u0027,\u0027) + \u0027\\n\u0027; msg.filename = global.get(\u0027gld_csv_path\u0027) || \u0027C:\\\\Users\\\\asus\\\\gld-dataset.csv\u0027; return msg;",
