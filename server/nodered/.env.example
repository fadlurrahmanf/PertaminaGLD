MQTT_HOST=CHANGE_ME_MQTT_HOST
MQTT_PORT=1884
MQTT_USER=<mqtt-user>
MQTT_PASS=<set-local-only>
GATEWAY_STATUS_URL=<disabled-until-http-debug-exists>
GATEWAY_BASE_URL=<disabled-until-http-debug-exists>
GLD_KEY_ID=1
GLD_AES128_KEY_HEX=<32-hex-key-from-secret-store>
PGL_COMMAND_AUTH_TOKEN=<at-least-32-random-characters>
NODE_RED_ADMIN_TOKEN=<node-red-admin-api-token>
PGL_REPLAY_STATE_PATH=<absolute-private-replay-state-json-path>
